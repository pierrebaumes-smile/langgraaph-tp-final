# Copiez ce fichier en .env et renseignez vos propres valeurs.

# --- Modèle de l'agent (Groq) ---
GROQ_API_KEY=
# Optionnel — voir https://console.groq.com/docs/models pour la liste à jour
GROQ_MODEL_NAME=qwen/qwen3-32b

# --- Tracing LangSmith (optionnel mais recommandé) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tp-final-langgraph-assistant
